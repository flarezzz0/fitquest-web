{
  "expo": {
    "name": "FitQuest",
    "slug": "fitquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fitquest",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "jsEngine": "jsc",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitquest.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1d1d1f"
      },
      "package": "com.fitquest.app",
      "jsEngine": "jsc"
    },
    "web": {
      "meta": {
        "viewport": "width=device-width, initial-scale=1, maximum-scale=1"
      },
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-image-picker",
      "expo-web-browser"
    ]
  }
}
